# region:app (addon-observability) — konfigurasi OpenTelemetry & metrics.
# OTEL_SERVICE_NAME dipakai sebagai nama service pada span tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT diisi bila mengirim trace ke collector OTLP
# (default skeleton memakai exporter stdout — endpoint dibiarkan kosong).
OTEL_SERVICE_NAME={{ .Name }}
OTEL_EXPORTER_OTLP_ENDPOINT=
