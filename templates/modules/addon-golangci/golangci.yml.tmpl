# .golangci.yml — konfigurasi golangci-lint v2 (skema "version: 2").
# Linter inti yang wajar untuk Go 1.26: cukup ketat untuk menjaga kualitas,
# tidak agresif sampai memecah project hasil generate. Bump versi tool aman (MINOR).
version: "2"

run:
  timeout: 5m

linters:
  # default: standard set golangci-lint (errcheck, govet, ineffassign,
  # staticcheck, unused). Tambah beberapa linter umum yang aman.
  default: standard
  enable:
    - bodyclose
    - gosec
    - misspell
    - revive
    - unconvert
  settings:
    staticcheck:
      checks:
        - all
  exclusions:
    # File ber-header generated (konvensi tooling Go) dilewati linter agar tidak
    # memunculkan temuan pada kode yang dihasilkan otomatis.
    generated: lax
    rules:
      # File test boleh memakai pola yang lebih longgar.
      - path: _test\.go
        linters:
          - gosec

formatters:
  enable:
    - gofmt
    - goimports
