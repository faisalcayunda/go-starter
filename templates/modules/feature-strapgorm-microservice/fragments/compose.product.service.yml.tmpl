  # service "product" (strapgorm: GET /api/products via GORM + gRPC Ping).
  product:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        SERVICE: product
    env_file:
      - .env
    environment:
{{- if eq .DB "mysql" }}
      # Password memakai ${DB_PASSWORD:-app} agar selaras dgn MYSQL_PASSWORD service mysql.
      PRODUCT_DB_DSN: "app:${DB_PASSWORD:-app}@tcp(mysql:3306)/app?parseTime=true&charset=utf8mb4&loc=Local"
{{- else }}
      # Password memakai ${DB_PASSWORD:-app} agar selaras dgn POSTGRES_PASSWORD service postgres.
      PRODUCT_DB_DSN: "host=postgres user=app password=${DB_PASSWORD:-app} dbname=app port=5432 sslmode=disable"
{{- end }}
    ports:
      - "{{ .ProductHTTPPort }}:{{ .ProductHTTPPort }}"
    depends_on:
{{- if eq .DB "mysql" }}
      - mysql
{{- else }}
      - postgres
{{- end }}
    restart: unless-stopped
