# GitHub Actions CI — lint, test, build untuk project Go.
# Berjalan pada push & pull_request ke branch utama. Job lint hanya hadir bila
# golangci-lint dikonfigurasi (add-on lint aktif). go-version dipin via var
# GoVersion agar selaras directive go.mod project.
name: ci

on:
  push:
    branches: [main, master]
  pull_request:

permissions:
  contents: read

jobs:
{{- if .Lint }}
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
      - name: golangci-lint
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest
{{- end }}

  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
          cache: true
      - name: go test
        run: go test ./...

  build:
    runs-on: ubuntu-latest
    needs: [test]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ .GoVersion }}"
          cache: true
      - name: go build
        run: go build ./...
