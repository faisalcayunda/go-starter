// Package server mengimplementasikan gRPC {{ toPascal .Service }}Service untuk
// service "{{ .Service }}". Ia meng-embed Unimplemented...Server (forward-compat:
// menambah rpc baru di proto tak memecah build) lalu menyediakan Ping.
package server

import (
	"context"
	"log/slog"

	{{ toSnake .Service }}v1 "{{ modJoin .ModulePath "gen/go" .Service "v1" }}"
)

// Server adalah implementasi {{ toPascal .Service }}ServiceServer.
type Server struct {
	{{ toSnake .Service }}v1.Unimplemented{{ toPascal .Service }}ServiceServer
	log *slog.Logger
}

// New membangun Server dengan logger terstruktur.
func New(log *slog.Logger) *Server {
	return &Server{log: log}
}

// Ping mengembalikan "pong dari service {{ .Service }}: <name>" — implementasi
// minimal yang membuktikan service hidup & dapat dipanggil lintas-service via
// gRPC. Pesan menyebut identitas service penjawab sehingga pemanggil dapat
// memverifikasi service tujuan mana yang benar-benar merespons.
func (s *Server) Ping(ctx context.Context, req *{{ toSnake .Service }}v1.PingRequest) (*{{ toSnake .Service }}v1.PingResponse, error) {
	s.log.Info("Ping diterima", slog.String("name", req.GetName()))
	return &{{ toSnake .Service }}v1.PingResponse{Message: "pong dari service {{ .Service }}: " + req.GetName()}, nil
}
