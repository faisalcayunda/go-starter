syntax = "proto3";

// Paket proto per service: <service>v1. Netral-bahasa; opsi go_package di-manage
// oleh buf (buf.gen.yaml managed mode, prefix <module>/gen/go) sehingga file .proto
// tetap bersih tanpa go_package literal.
package {{ toSnake .Service }}v1;

// {{ toPascal .Service }}Service adalah kontrak minimal service "{{ .Service }}".
// rpc Ping membuktikan service hidup & dapat dipanggil lintas-service via gRPC.
service {{ toPascal .Service }}Service {
  // Ping mengembalikan pesan "pong dari service {{ .Service }}: <name>" — dipakai contoh inter-service call.
  rpc Ping(PingRequest) returns (PingResponse);
}

// PingRequest membawa nama pemanggil (echo-back pada response).
message PingRequest {
  string name = 1;
}

// PingResponse membawa pesan balasan service.
message PingResponse {
  string message = 1;
}
