# demo-chi — contoh environment (.env.example).
# File shared ber-anchor: modul lain menyumbang blok ke anchor app/database/broker.

# region:app — variabel aplikasi inti (disumbang modul core ke .env.example).
APP_NAME=demo-chi
APP_PORT=8080
# region:app (addon-env) — variabel runtime generik tambahan.
ENV=development
LOG_LEVEL=info
# region:database (db-postgres) — kredensial koneksi PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASSWORD=postgres
# region:broker
